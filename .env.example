# ─── OpenAI ─────────────────────────────────────────────────────────────────
# Klucz API z https://platform.openai.com/api-keys (sk-proj-...)
OPENAI_API_KEY=sk-proj-xxx
OPENAI_MODEL=gpt-5.4

# ─── Database ───────────────────────────────────────────────────────────────
# PostgreSQL connection string. Vercel Postgres / Neon / Supabase / własny.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/memoist?sslmode=require

# ─── Auth ───────────────────────────────────────────────────────────────────
# Sekret do podpisywania JWT. Wygeneruj: openssl rand -base64 32
AUTH_SECRET=zmień_mnie_na_32_bajtowy_losowy_secret

# Email konta admin. Pierwszy użytkownik zarejestrowany z tym adresem
# automatycznie dostaje rolę ADMIN. Zmień przed deployem!
ADMIN_EMAIL=admin@twojadomena.pl

# ─── Tokens / billing ───────────────────────────────────────────────────────
# Ile tokenów dostaje nowy użytkownik na start (do pierwszych testów).
SIGNUP_TOKEN_GIFT=5
