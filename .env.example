# Klucz API OpenAI — uzyskaj na https://platform.openai.com/api-keys
# Required for AI document generation
OPENAI_API_KEY=sk-proj-xxx

# (Opcjonalnie) Model do użycia. Domyślnie: gpt-5.4
# Dostępne (kwiecień 2026):
#   gpt-5.5         — najnowszy flagship (najlepsza jakość, wyższa cena $5/$30 per 1M)
#   gpt-5.4         — stabilny default (balans jakość/cena)
#   gpt-5.4-mini    — szybszy i tańszy
#   gpt-5.4-nano    — najtańszy, niższa jakość dokumentacji formalnej
OPENAI_MODEL=gpt-5.4
